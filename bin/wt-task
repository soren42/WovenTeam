#!/usr/bin/env bash
set -euo pipefail

ROOM_URL="${WT_ROOM_URL:-http://127.0.0.1:8787}"

usage() {
    cat <<'USAGE'
Usage:
  wt-task create --title TITLE --body BODY --role ROLE [--agent AGENT] [--initiative INIT] [--priority P] [--model MODEL] [--tool-profile PROFILE] [--max-tokens N]
  wt-task request --parent TASK_ID --by-role ROLE --role ROLE --title TITLE --body BODY [--by NAME] [--agent AGENT] [--initiative INIT] [--priority P] [--model MODEL] [--tool-profile PROFILE] [--max-tokens N]
  wt-task initiative create --title TITLE --body BODY [--id INIT] [--role ROLE] [--agent AGENT] [--max-tokens N]
  wt-task initiative list
  wt-task initiative show INIT
  wt-task initiative export INIT
  wt-task initiative close INIT [--message TEXT]
  wt-task agent list
  wt-task agent pause AGENT [--message TEXT]
  wt-task agent resume AGENT [--message TEXT]
  wt-task list
  wt-task show TASK_ID
  wt-task assign TASK_ID --agent AGENT [--status assigned]
  wt-task update-status TASK_ID --status STATUS [--message TEXT]
  wt-task retry TASK_ID [--message TEXT]
  wt-task cancel TASK_ID [--message TEXT]
  wt-task close TASK_ID [--message TEXT]
  wt-task reopen TASK_ID [--message TEXT]

Environment:
  WT_ROOM_URL  wt-roomd base URL, default http://127.0.0.1:8787
USAGE
}

require_jq() {
    if ! command -v jq >/dev/null 2>&1; then
        echo "wt-task: jq is required" >&2
        exit 2
    fi
}

http_get() {
    curl -fsS "$ROOM_URL$1"
}

http_post_json() {
    local path="$1"
    local json="$2"
    curl -fsS -H 'Content-Type: application/json' -d "$json" "$ROOM_URL$path"
}

now_ms() {
    local seconds nanoseconds
    seconds="$(date +%s)"
    nanoseconds="$(date +%N)"
    printf '%s%03d\n' "$seconds" "$((10#$nanoseconds / 1000000))"
}

new_id() {
    local prefix="$1"
    if command -v uuidgen >/dev/null 2>&1; then
        printf '%s_%s\n' "$prefix" "$(uuidgen | tr '[:upper:]' '[:lower:]' | tr -d '-')"
    else
        printf '%s_%s_%s\n' "$prefix" "$(date +%s)" "$RANDOM"
    fi
}

cmd_create() {
    local title="" body="" role="" agent="" initiative="" priority="normal" model="openai/gpt-5.3-codex" tool_profile="observe" max_tokens="2000000"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --title) title="${2:-}"; shift 2 ;;
            --body) body="${2:-}"; shift 2 ;;
            --role) role="${2:-}"; shift 2 ;;
            --agent) agent="${2:-}"; shift 2 ;;
            --initiative) initiative="${2:-}"; shift 2 ;;
            --priority) priority="${2:-}"; shift 2 ;;
            --model) model="${2:-}"; shift 2 ;;
            --tool-profile) tool_profile="${2:-}"; shift 2 ;;
            --max-tokens) max_tokens="${2:-}"; shift 2 ;;
            *) echo "wt-task create: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$title" || -z "$body" || -z "$role" ]]; then
        echo "wt-task create: --title, --body, and --role are required" >&2
        exit 2
    fi
    [[ -n "$agent" ]] || agent="all"
    [[ -n "$initiative" ]] || initiative="$(new_id init)"
    local task_id created_at
    task_id="$(new_id task)"
    created_at="$(now_ms)"
    local json
    json="$(jq -cn \
        --arg taskId "$task_id" \
        --arg initiativeId "$initiative" \
        --arg createdBy "ceo" \
        --arg assignedRole "$role" \
        --arg assignedAgent "$agent" \
        --arg modelId "$model" \
        --arg priority "$priority" \
        --arg toolProfile "$tool_profile" \
        --arg title "$title" \
        --arg body "$body" \
        --argjson createdAtUnixMs "$created_at" \
        --argjson maxTokens "$max_tokens" \
        '{
          schema:"woventeam.task_package.v0.1",
          taskId:$taskId,
          initiativeId:$initiativeId,
          createdBy:$createdBy,
          assignedRole:$assignedRole,
          assignedAgent:$assignedAgent,
          modelId:$modelId,
          priority:$priority,
          status:"queued",
          title:$title,
          body:$body,
          task:{title:$title, body:$body, deliverables:[]},
          contextRefs:[],
          acceptanceCriteria:["Task result is recorded in the room and task ledger."],
          toolPolicy:{
            profile:$toolProfile,
            filesystem:(if $toolProfile == "repo_branch" or $toolProfile == "test_local" then "workspace_write" else "read_only" end),
            network:(if $toolProfile == "test_local" then "loopback" else "none" end),
            system:"none",
            git:(if $toolProfile == "repo_branch" or $toolProfile == "test_local" then "branch_only" else "none" end)
          },
          budget:{timeoutSeconds:1800, maxOutputBytes:1048576, maxCostUsd:1.0, maxTokens:$maxTokens},
          dependencies:[],
          createdAtUnixMs:$createdAtUnixMs
        }')"
    http_post_json "/api/task-package" "$json"
}

cmd_request() {
    local parent="" by_role="" by="" role="" title="" body="" agent="" initiative="" priority="normal" model="openai/gpt-5.3-codex" tool_profile="observe" max_tokens="2000000"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --parent) parent="${2:-}"; shift 2 ;;
            --by-role) by_role="${2:-}"; shift 2 ;;
            --by) by="${2:-}"; shift 2 ;;
            --role) role="${2:-}"; shift 2 ;;
            --title) title="${2:-}"; shift 2 ;;
            --body) body="${2:-}"; shift 2 ;;
            --agent) agent="${2:-}"; shift 2 ;;
            --initiative) initiative="${2:-}"; shift 2 ;;
            --priority) priority="${2:-}"; shift 2 ;;
            --model) model="${2:-}"; shift 2 ;;
            --tool-profile) tool_profile="${2:-}"; shift 2 ;;
            --max-tokens) max_tokens="${2:-}"; shift 2 ;;
            *) echo "wt-task request: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$parent" || -z "$by_role" || -z "$role" || -z "$title" || -z "$body" ]]; then
        echo "wt-task request: --parent, --by-role, --role, --title, and --body are required" >&2
        exit 2
    fi
    [[ -n "$by" ]] || by="$by_role"
    [[ -n "$initiative" ]] || initiative="$(new_id init)"
    local task_id created_at
    task_id="$(new_id task)"
    created_at="$(now_ms)"
    local json
    json="$(jq -cn \
        --arg parentTaskId "$parent" \
        --arg requestedTaskId "$task_id" \
        --arg initiativeId "$initiative" \
        --arg requestedBy "$by" \
        --arg requestedByRole "$by_role" \
        --arg requestedRole "$role" \
        --arg assignedAgent "$agent" \
        --arg modelId "$model" \
        --arg priority "$priority" \
        --arg toolProfile "$tool_profile" \
        --arg title "$title" \
        --arg body "$body" \
        --argjson createdAtUnixMs "$created_at" \
        --argjson maxTokens "$max_tokens" \
        '{
          schema:"woventeam.task_request.v0.1",
          taskId:$requestedTaskId,
          parentTaskId:$parentTaskId,
          requestedTaskId:$requestedTaskId,
          initiativeId:$initiativeId,
          requestedBy:$requestedBy,
          requestedByRole:$requestedByRole,
          requestedRole:$requestedRole,
          modelId:$modelId,
          priority:$priority,
          title:$title,
          body:$body,
          toolPolicy:{profile:$toolProfile},
          budget:{maxTokens:$maxTokens},
          createdAtUnixMs:$createdAtUnixMs
        } + (if $assignedAgent == "" then {} else {assignedAgent:$assignedAgent} end)')"
    http_post_json "/api/task-request" "$json"
}

cmd_list() {
    http_get "/api/task-summaries" | jq -r '
      .[] | [.taskId, .status, .assignedAgent, .assignedRole, .eventCount, .title] | @tsv'
}

cmd_show() {
    local task_id="${1:-}"
    if [[ -z "$task_id" ]]; then
        echo "wt-task show: TASK_ID is required" >&2
        exit 2
    fi
    http_get "/api/task-detail?taskId=$task_id" | jq .
}

cmd_initiative() {
    local subcmd="${1:-}"
    shift || true
    case "$subcmd" in
        create)
            local title="" body="" initiative="" role="project_manager" agent="router" max_tokens="2000000"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --title) title="${2:-}"; shift 2 ;;
                    --body) body="${2:-}"; shift 2 ;;
                    --id) initiative="${2:-}"; shift 2 ;;
                    --role) role="${2:-}"; shift 2 ;;
                    --agent) agent="${2:-}"; shift 2 ;;
                    --max-tokens) max_tokens="${2:-}"; shift 2 ;;
                    *) echo "wt-task initiative create: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$title" || -z "$body" ]]; then
                echo "wt-task initiative create: --title and --body are required" >&2
                exit 2
            fi
            [[ -n "$initiative" ]] || initiative="$(new_id init)"
            cmd_create --title "$title" --body "$body" --role "$role" --agent "$agent" \
                --initiative "$initiative" --tool-profile observe --max-tokens "$max_tokens"
            ;;
        list)
            http_get "/api/initiatives" | jq -r '
              .initiatives[] | [.initiativeId, .activeTasks, .taskCount, .blockedTasks, .openGateTasks, .maxTokens, .title] | @tsv'
            ;;
        show)
            local initiative="${1:-}"
            if [[ -z "$initiative" ]]; then
                echo "wt-task initiative show: INIT is required" >&2
                exit 2
            fi
            http_get "/api/initiative-detail?initiativeId=$initiative" | jq .
            ;;
        export)
            local initiative="${1:-}"
            if [[ -z "$initiative" ]]; then
                echo "wt-task initiative export: INIT is required" >&2
                exit 2
            fi
            http_get "/api/initiative-detail?initiativeId=$initiative" | jq .
            ;;
        close)
            local initiative="${1:-}" message="Initiative closed by wt-task."
            shift || true
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --message) message="${2:-}"; shift 2 ;;
                    *) echo "wt-task initiative close: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$initiative" ]]; then
                echo "wt-task initiative close: INIT is required" >&2
                exit 2
            fi
            http_get "/api/initiative-detail?initiativeId=$initiative" |
              jq -r '.tasks[] | select(.status as $s | ["complete","failed","cancelled","closed"] | index($s) | not) | .taskId' |
              while read -r task_id; do
                  [[ -n "$task_id" ]] || continue
                  cmd_lifecycle closed "$message" "$task_id" >/dev/null
              done
            http_get "/api/initiative-detail?initiativeId=$initiative" | jq .
            ;;
        -h|--help|help|"")
            usage
            ;;
        *)
            echo "wt-task initiative: unknown command: $subcmd" >&2
            usage >&2
            exit 2
            ;;
    esac
}

cmd_agent() {
    local subcmd="${1:-}"
    shift || true
    case "$subcmd" in
        list)
            http_get "/api/agents" | jq -r '
              .agents[] | [.agent, .state, .activeTasks, .leasedTasks, .runningTasks, .stuckTasks, .attempts, .message] | @tsv'
            ;;
        pause|resume)
            local agent="${1:-}" message=""
            shift || true
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --message) message="${2:-}"; shift 2 ;;
                    *) echo "wt-task agent $subcmd: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$agent" ]]; then
                echo "wt-task agent $subcmd: AGENT is required" >&2
                exit 2
            fi
            [[ -n "$message" ]] || message="Agent $subcmd requested by wt-task."
            jq -cn --arg agent "$agent" --arg action "$subcmd" --arg message "$message" \
                '{agent:$agent,action:$action,message:$message,createdBy:"ceo"}' |
              http_post_json "/api/agent-control" "$(cat)"
            ;;
        -h|--help|help|"")
            usage
            ;;
        *)
            echo "wt-task agent: unknown command: $subcmd" >&2
            usage >&2
            exit 2
            ;;
    esac
}

cmd_lifecycle() {
    local status="$1" default_message="$2" task_id="${3:-}" message=""
    shift || true
    shift || true
    shift || true
    message="$default_message"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --message) message="${2:-}"; shift 2 ;;
            *) echo "wt-task $status: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$task_id" ]]; then
        echo "wt-task $status: TASK_ID is required" >&2
        exit 2
    fi
    local created_at json
    created_at="$(now_ms)"
    json="$(jq -cn \
        --arg taskId "$task_id" \
        --arg status "$status" \
        --arg message "$message" \
        --arg createdBy "ceo" \
        --argjson createdAtUnixMs "$created_at" \
        '{schema:"woventeam.task_event.v0.1",taskId:$taskId,eventType:"lifecycle",status:$status,message:$message,createdBy:$createdBy,createdAtUnixMs:$createdAtUnixMs}')"
    http_post_json "/api/task-event" "$json"
}

cmd_assign() {
    local task_id="${1:-}" agent="" status="assigned"
    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent) agent="${2:-}"; shift 2 ;;
            --status) status="${2:-}"; shift 2 ;;
            *) echo "wt-task assign: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$task_id" || -z "$agent" ]]; then
        echo "wt-task assign: TASK_ID and --agent are required" >&2
        exit 2
    fi
    local created_at json
    created_at="$(now_ms)"
    json="$(jq -cn \
        --arg taskId "$task_id" \
        --arg status "$status" \
        --arg assignedAgent "$agent" \
        --arg createdBy "ceo" \
        --argjson createdAtUnixMs "$created_at" \
        '{schema:"woventeam.task_event.v0.1",taskId:$taskId,eventType:"assignment",status:$status,assignedAgent:$assignedAgent,message:"Task assigned by wt-task.",createdBy:$createdBy,createdAtUnixMs:$createdAtUnixMs}')"
    http_post_json "/api/task-event" "$json"
}

cmd_update_status() {
    local task_id="${1:-}" status="" message="Task status updated by wt-task."
    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status) status="${2:-}"; shift 2 ;;
            --message) message="${2:-}"; shift 2 ;;
            *) echo "wt-task update-status: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$task_id" || -z "$status" ]]; then
        echo "wt-task update-status: TASK_ID and --status are required" >&2
        exit 2
    fi
    local created_at json
    created_at="$(now_ms)"
    json="$(jq -cn \
        --arg taskId "$task_id" \
        --arg status "$status" \
        --arg message "$message" \
        --arg createdBy "ceo" \
        --argjson createdAtUnixMs "$created_at" \
        '{schema:"woventeam.task_event.v0.1",taskId:$taskId,eventType:"status",status:$status,message:$message,createdBy:$createdBy,createdAtUnixMs:$createdAtUnixMs}')"
    http_post_json "/api/task-event" "$json"
}

require_jq
cmd="${1:-}"
shift || true
case "$cmd" in
    create) cmd_create "$@" ;;
    request) cmd_request "$@" ;;
    initiative) cmd_initiative "$@" ;;
    agent) cmd_agent "$@" ;;
    list) cmd_list "$@" ;;
    show) cmd_show "$@" ;;
    assign) cmd_assign "$@" ;;
    update-status) cmd_update_status "$@" ;;
    retry) cmd_lifecycle queued "Task reopened for retry by wt-task." "$@" ;;
    cancel) cmd_lifecycle cancelled "Task cancelled by wt-task." "$@" ;;
    close) cmd_lifecycle closed "Task closed by wt-task." "$@" ;;
    reopen) cmd_lifecycle queued "Task reopened by wt-task." "$@" ;;
    -h|--help|help|"") usage ;;
    *) echo "wt-task: unknown command: $cmd" >&2; usage >&2; exit 2 ;;
esac
