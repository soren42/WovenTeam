#!/usr/bin/env bash
set -euo pipefail

ROOM_URL="${WT_ROOM_URL:-http://127.0.0.1:8787}"
OPERATOR_SESSION="${WT_OPERATOR_SESSION:-}"

usage() {
    cat <<'USAGE'
Usage:
  wt-task create --title TITLE --body BODY --role ROLE [--agent AGENT] [--initiative INIT] [--priority P] [--model MODEL] [--tool-profile PROFILE] [--max-tokens N] [--autonomy-level LEVEL] [--autonomy-ttl SECONDS] [--autonomy-scope SCOPE]
  wt-task request --parent TASK_ID --by-role ROLE --role ROLE --title TITLE --body BODY [--by NAME] [--agent AGENT] [--initiative INIT] [--priority P] [--model MODEL] [--tool-profile PROFILE] [--max-tokens N] [--autonomy-level LEVEL] [--autonomy-ttl SECONDS] [--autonomy-scope SCOPE]
  wt-task initiative create --title TITLE --body BODY [--id INIT] [--role ROLE] [--agent AGENT] [--max-tokens N]
  wt-task initiative list
  wt-task initiative show INIT
  wt-task initiative export INIT
  wt-task initiative report INIT [--out FILE]
  wt-task initiative close INIT [--message TEXT]
  wt-task agent list
  wt-task agent pause AGENT [--message TEXT]
  wt-task agent resume AGENT [--message TEXT]
  wt-task reclaim TASK_ID [--reason operator|lease_expired] [--message TEXT]
  wt-task cancel-task TASK_ID [--reason TEXT] [--message TEXT]
  wt-task artifact promote TASK_ID [--path PATH] [--reviewer NAME] [--notes TEXT]
  wt-task artifact reject TASK_ID [--path PATH] [--reviewer NAME] [--notes TEXT]
  wt-task artifact review TASK_ID [--path PATH] [--reviewer NAME] [--notes TEXT]
  wt-task artifact supersede TASK_ID [--path PATH] [--reviewer NAME] [--notes TEXT]
  wt-task artifact note TASK_ID --notes TEXT [--reviewer NAME]
  wt-task artifact list INIT
  wt-task artifact export TASK_ID [--out FILE]
  wt-task artifact ship TASK_ID [--mode copy|tarball|branch|pr] [--reviewer NAME] [--supersedes ID] [--repo PATH] [--yes] [--pr-title T] [--pr-body B] [--dest-basename NAME]
  wt-task audit INIT [--out FILE]
  wt-task autonomy revoke TASK_ID [--reason TEXT]
  wt-task list
  wt-task show TASK_ID
  wt-task assign TASK_ID --agent AGENT [--status assigned]
  wt-task update-status TASK_ID --status STATUS [--message TEXT]
  wt-task retry TASK_ID [--message TEXT]
  wt-task cancel TASK_ID [--message TEXT]
  wt-task close TASK_ID [--message TEXT]
  wt-task reopen TASK_ID [--message TEXT]

Environment:
  WT_ROOM_URL  wt-roomd base URL, default http://127.0.0.1:8787
USAGE
}

require_jq() {
    if ! command -v jq >/dev/null 2>&1; then
        echo "wt-task: jq is required" >&2
        exit 2
    fi
}

http_get() {
    curl -fsS "$ROOM_URL$1"
}

http_post_json() {
    local path="$1"
    local json="$2"
    local -a headers=(-H 'Content-Type: application/json')
    if [[ -z "$OPERATOR_SESSION" ]]; then
        OPERATOR_SESSION="$(curl -fsS "$ROOM_URL/api/operator-session" 2>/dev/null | jq -r '.operatorSession // empty' || true)"
    fi
    if [[ -n "$OPERATOR_SESSION" ]]; then
        headers+=(-H "X-WovenTeam-Operator-Session: $OPERATOR_SESSION")
    fi
    curl -fsS "${headers[@]}" -d "$json" "$ROOM_URL$path"
}

now_ms() {
    local seconds nanoseconds
    seconds="$(date +%s)"
    nanoseconds="$(date +%N)"
    printf '%s%03d\n' "$seconds" "$((10#$nanoseconds / 1000000))"
}

new_id() {
    local prefix="$1"
    if command -v uuidgen >/dev/null 2>&1; then
        printf '%s_%s\n' "$prefix" "$(uuidgen | tr '[:upper:]' '[:lower:]' | tr -d '-')"
    else
        printf '%s_%s_%s\n' "$prefix" "$(date +%s)" "$RANDOM"
    fi
}

# Phase 3 Sprint 7: render an initiative audit JSON payload as a self-contained
# HTML report. $1 = audit JSON, $2 = generated-at ISO timestamp. All data is
# @html-escaped by jq so a task title containing markup cannot break the
# document or inject script. Emits the full document to stdout.
render_initiative_report() {
    local audit="$1" generated="$2"
    # Static head + inline CSS (no escaping concerns - no interpolated data).
    cat <<HTMLHEAD
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>WovenTeam initiative report</title>
<style>
  :root { --ink:#17202a; --muted:#5c6875; --line:#d7dee6; --paper:#f7f9fb; --panel:#fff; --blue:#2563a8; --green:#1f7a5a; --amber:#a16207; --red:#b42318; }
  * { box-sizing:border-box; }
  body { margin:0; font-family:ui-sans-serif,system-ui,-apple-system,"Segoe UI",sans-serif; color:var(--ink); background:var(--paper); line-height:1.48; }
  header.hero { background:#11253a; color:#fff; padding:32px clamp(18px,5vw,56px) 26px; }
  header.hero h1 { margin:0 0 8px; font-size:clamp(26px,4vw,40px); }
  header.hero .meta { color:#aac4dd; font-size:13px; }
  main { max-width:1100px; margin:0 auto; padding:24px clamp(16px,4vw,28px) 48px; }
  section { margin:0 0 24px; padding:20px; background:var(--panel); border:1px solid var(--line); border-radius:8px; }
  h2 { margin:0 0 12px; font-size:20px; }
  table { width:100%; border-collapse:collapse; font-size:13px; }
  th,td { text-align:left; vertical-align:top; padding:8px 9px; border-bottom:1px solid var(--line); }
  th { background:#f0f4f8; }
  code { font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; font-size:0.92em; background:#eef2f6; padding:1px 4px; border-radius:4px; }
  .cards { display:flex; flex-wrap:wrap; gap:10px; }
  .card { flex:1 1 120px; border:1px solid var(--line); border-radius:6px; padding:10px 12px; background:#fbfcfe; }
  .card b { display:block; font-size:22px; }
  .card span { font-size:11px; text-transform:uppercase; letter-spacing:0.04em; color:var(--muted); }
  .pill { display:inline-block; border:1px solid var(--line); border-radius:999px; padding:1px 7px; font-size:11px; font-weight:700; background:#f6f8fa; color:var(--muted); }
  .pill.hit { color:var(--red); border-color:#f0c2bd; background:#fdeceb; }
  .pill.clean { color:var(--green); border-color:#b7dfcd; background:#e7f5ee; }
  .empty { color:var(--muted); font-style:italic; }
  .muted { color:var(--muted); font-size:12px; }
</style>
</head>
<body>
HTMLHEAD

    # Dynamic body: one jq program emits the whole <body> inner content,
    # @html-escaping every interpolated value.
    jq -r --arg generated "$generated" '
      def esc: (. // "") | tostring | @html;
      def ms2iso: if (. // 0) > 0 then (. / 1000 | floor | todate) else "—" end;
      def emptyrow($cols; $msg): "<tr><td colspan=\"" + ($cols|tostring) + "\" class=\"empty\">" + $msg + "</td></tr>";

      "<header class=\"hero\"><h1>" + (.summary.title // .initiativeId | esc) + "</h1>"
      + "<div class=\"meta\">Initiative <code>" + (.initiativeId | esc) + "</code> · generated " + ($generated | esc)
      + " · created " + (.summary.createdAtUnixMs | ms2iso) + " · updated " + (.summary.updatedAtUnixMs | ms2iso) + "</div></header>"
      + "<main>"

      # Summary cards
      + "<section><h2>Summary</h2><div class=\"cards\">"
      + "<div class=\"card\"><b>" + (.summary.taskCount // 0 | tostring) + "</b><span>tasks</span></div>"
      + "<div class=\"card\"><b>" + (.summary.activeTasks // 0 | tostring) + "</b><span>active</span></div>"
      + "<div class=\"card\"><b>" + (.summary.completeTasks // 0 | tostring) + "</b><span>complete</span></div>"
      + "<div class=\"card\"><b>" + (.summary.failedTasks // 0 | tostring) + "</b><span>failed</span></div>"
      + "<div class=\"card\"><b>" + (.summary.acceptedArtifacts // 0 | tostring) + "</b><span>accepted</span></div>"
      + "<div class=\"card\"><b>" + ((.deliverables // []) | length | tostring) + "</b><span>deliverables</span></div>"
      + "<div class=\"card\"><b>" + (.summary.maxTokens // 0 | tostring) + "</b><span>max tokens</span></div>"
      + "</div></section>"

      # Tasks
      + "<section><h2>Tasks</h2><table><thead><tr><th>Task</th><th>Status</th><th>Role</th><th>Agent</th><th>Priority</th><th>Title</th></tr></thead><tbody>"
      + ( (.tasks // []) | if length == 0 then emptyrow(6; "No tasks.")
          else (map("<tr><td><code>" + (.taskId|esc) + "</code></td><td>" + (.status|esc)
            + "</td><td>" + (.assignedRole|esc) + "</td><td>" + ((.assignedAgent // "all")|esc)
            + "</td><td>" + ((.priority // "normal")|esc) + "</td><td>" + (.title|esc) + "</td></tr>") | join("")) end )
      + "</tbody></table></section>"

      # Deliverables
      + "<section><h2>Deliverables</h2><table><thead><tr><th>Path</th><th>Mode</th><th>SHA-256</th><th>Size</th><th>Reviewer</th><th>When</th></tr></thead><tbody>"
      + ( (.deliverables // []) | if length == 0 then emptyrow(6; "No deliverables shipped.")
          else (map("<tr><td><code>" + (.deliverablePath|esc) + "</code></td><td>" + (.packagingMode|esc)
            + "</td><td><code>" + ((.sha256 // "")[0:16]|esc) + "</code></td><td>" + (.sizeBytes // 0 | tostring)
            + "</td><td>" + (.reviewer|esc) + "</td><td>" + (.createdAtUnixMs|ms2iso) + "</td></tr>") | join("")) end )
      + "</tbody></table></section>"

      # Secret scans
      + "<section><h2>Secret scans</h2><table><thead><tr><th>Scanned path</th><th>Result</th><th>Hits</th><th>Mode</th><th>When</th></tr></thead><tbody>"
      + ( (.secretScans // []) | if length == 0 then emptyrow(5; "No secret scans recorded.")
          else (map("<tr><td><code>" + (.scannedPath|esc) + "</code></td><td>"
            + (if .matched then "<span class=\"pill hit\">match</span>" else "<span class=\"pill clean\">clean</span>" end)
            + "</td><td>" + (.hitCount // 0 | tostring) + "</td><td>" + (.packagingMode|esc)
            + "</td><td>" + (.createdAtUnixMs|ms2iso) + "</td></tr>") | join("")) end )
      + "</tbody></table></section>"

      # Policy denials
      + "<section><h2>Policy denials</h2><table><thead><tr><th>Task</th><th>Reason</th><th>Detail</th></tr></thead><tbody>"
      + ( (.policyDecisions // []) | if length == 0 then emptyrow(3; "No policy denials.")
          else (map("<tr><td><code>" + ((.taskId // "—")|esc) + "</code></td><td>" + ((.reason // "")|esc)
            + "</td><td>" + ((.detail // .message // "")|esc) + "</td></tr>") | join("")) end )
      + "</tbody></table></section>"

      # Autonomy + key events (from the events stream)
      + "<section><h2>Event timeline</h2><table><thead><tr><th>When</th><th>Type</th><th>Status</th><th>Agent</th><th>Message</th></tr></thead><tbody>"
      + ( (.events // []) | if length == 0 then emptyrow(5; "No events.")
          else (map("<tr><td>" + (.createdAtUnixMs|ms2iso) + "</td><td>" + ((.eventType // "")|esc)
            + "</td><td>" + ((.status // "")|esc) + "</td><td>" + ((.assignedAgent // "")|esc)
            + "</td><td>" + ((.message // "")|esc) + "</td></tr>") | join("")) end )
      + "</tbody></table></section>"

      + "<p class=\"muted\">Generated by <code>wt-task initiative report</code> from <code>/api/initiative-audit</code>. All values are HTML-escaped at render time.</p>"
      + "</main></body></html>"
    ' <<<"$audit"
}

cmd_create() {
    # Sprint 5: leave model empty by default. The daemon auto-defaults to a
    # family that matches the routed (or pinned) agent. This way an operator
    # who passes `--agent claude` without `--model` no longer ships an OpenAI
    # default that trips the policy model_agent_mismatch rule.
    local title="" body="" role="" agent="" initiative="" priority="normal" model="" tool_profile="observe" max_tokens="2000000"
    local autonomy_level="" autonomy_ttl="0" autonomy_scope="" autonomy_network="none" autonomy_credential="none" autonomy_clean="0"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --title) title="${2:-}"; shift 2 ;;
            --body) body="${2:-}"; shift 2 ;;
            --role) role="${2:-}"; shift 2 ;;
            --agent) agent="${2:-}"; shift 2 ;;
            --initiative) initiative="${2:-}"; shift 2 ;;
            --priority) priority="${2:-}"; shift 2 ;;
            --model) model="${2:-}"; shift 2 ;;
            --tool-profile) tool_profile="${2:-}"; shift 2 ;;
            --max-tokens) max_tokens="${2:-}"; shift 2 ;;
            --autonomy-level) autonomy_level="${2:-}"; shift 2 ;;
            --autonomy-ttl) autonomy_ttl="${2:-}"; shift 2 ;;
            --autonomy-scope) autonomy_scope="${2:-}"; shift 2 ;;
            --autonomy-network) autonomy_network="${2:-}"; shift 2 ;;
            --credential-class) autonomy_credential="${2:-}"; shift 2 ;;
            --requires-clean-worktree) autonomy_clean="1"; shift ;;
            *) echo "wt-task create: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$title" || -z "$body" || -z "$role" ]]; then
        echo "wt-task create: --title, --body, and --role are required" >&2
        exit 2
    fi
    [[ -n "$agent" ]] || agent="all"
    [[ -n "$initiative" ]] || initiative="$(new_id init)"
    local task_id created_at
    task_id="$(new_id task)"
    created_at="$(now_ms)"
    local json
    json="$(jq -cn \
        --arg taskId "$task_id" \
        --arg initiativeId "$initiative" \
        --arg createdBy "ceo" \
        --arg assignedRole "$role" \
        --arg assignedAgent "$agent" \
        --arg modelId "$model" \
        --arg priority "$priority" \
        --arg toolProfile "$tool_profile" \
        --arg title "$title" \
        --arg body "$body" \
        --arg autonomyLevel "$autonomy_level" \
        --arg autonomyScope "$autonomy_scope" \
        --arg autonomyNetwork "$autonomy_network" \
        --arg autonomyCredential "$autonomy_credential" \
        --argjson createdAtUnixMs "$created_at" \
        --argjson maxTokens "$max_tokens" \
        --argjson autonomyTtl "$autonomy_ttl" \
        --argjson autonomyClean "$autonomy_clean" \
        '{
          schema:"woventeam.task_package.v0.1",
          taskId:$taskId,
          initiativeId:$initiativeId,
          createdBy:$createdBy,
          assignedRole:$assignedRole,
          assignedAgent:$assignedAgent,
          modelId:$modelId,
          priority:$priority,
          status:"queued",
          title:$title,
          body:$body,
          task:{title:$title, body:$body, deliverables:[]},
          contextRefs:[],
          acceptanceCriteria:["Task result is recorded in the room and task ledger."],
          toolPolicy:{
            profile:$toolProfile,
            filesystem:(if $toolProfile == "repo_branch" or $toolProfile == "test_local" then "workspace_write" else "read_only" end),
            network:(if $toolProfile == "test_local" then "loopback" else "none" end),
            system:"none",
            git:(if $toolProfile == "repo_branch" or $toolProfile == "test_local" then "branch_only" else "none" end)
          },
          budget:{timeoutSeconds:1800, maxOutputBytes:1048576, maxCostUsd:1.0, maxTokens:$maxTokens},
          dependencies:[],
          createdAtUnixMs:$createdAtUnixMs
        }
        + (if $autonomyLevel == "" then {} else {autonomyLevel:$autonomyLevel} end)
        + (if $autonomyLevel == "" and $autonomyScope == "" and $autonomyTtl == 0 then {} else {
            autonomyGrant:{
              scope:$autonomyScope,
              ttlSeconds:$autonomyTtl,
              maxWallClockSeconds:1800,
              maxCostUsd:1.0,
              maxTokens:$maxTokens,
              network:$autonomyNetwork,
              credentialClass:$autonomyCredential,
              requiresCleanWorktree:($autonomyClean != 0)
            }
          } end)')"
    http_post_json "/api/task-package" "$json"
}

cmd_request() {
    # Sprint 5: same blank-model default as cmd_create (see comment there).
    local parent="" by_role="" by="" role="" title="" body="" agent="" initiative="" priority="normal" model="" tool_profile="observe" max_tokens="2000000"
    local autonomy_level="" autonomy_ttl="0" autonomy_scope="" autonomy_network="none" autonomy_credential="none" autonomy_clean="0"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --parent) parent="${2:-}"; shift 2 ;;
            --by-role) by_role="${2:-}"; shift 2 ;;
            --by) by="${2:-}"; shift 2 ;;
            --role) role="${2:-}"; shift 2 ;;
            --title) title="${2:-}"; shift 2 ;;
            --body) body="${2:-}"; shift 2 ;;
            --agent) agent="${2:-}"; shift 2 ;;
            --initiative) initiative="${2:-}"; shift 2 ;;
            --priority) priority="${2:-}"; shift 2 ;;
            --model) model="${2:-}"; shift 2 ;;
            --tool-profile) tool_profile="${2:-}"; shift 2 ;;
            --max-tokens) max_tokens="${2:-}"; shift 2 ;;
            --autonomy-level) autonomy_level="${2:-}"; shift 2 ;;
            --autonomy-ttl) autonomy_ttl="${2:-}"; shift 2 ;;
            --autonomy-scope) autonomy_scope="${2:-}"; shift 2 ;;
            --autonomy-network) autonomy_network="${2:-}"; shift 2 ;;
            --credential-class) autonomy_credential="${2:-}"; shift 2 ;;
            --requires-clean-worktree) autonomy_clean="1"; shift ;;
            *) echo "wt-task request: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$parent" || -z "$by_role" || -z "$role" || -z "$title" || -z "$body" ]]; then
        echo "wt-task request: --parent, --by-role, --role, --title, and --body are required" >&2
        exit 2
    fi
    [[ -n "$by" ]] || by="$by_role"
    [[ -n "$initiative" ]] || initiative="$(new_id init)"
    local task_id created_at
    task_id="$(new_id task)"
    created_at="$(now_ms)"
    local json
    json="$(jq -cn \
        --arg parentTaskId "$parent" \
        --arg requestedTaskId "$task_id" \
        --arg initiativeId "$initiative" \
        --arg requestedBy "$by" \
        --arg requestedByRole "$by_role" \
        --arg requestedRole "$role" \
        --arg assignedAgent "$agent" \
        --arg modelId "$model" \
        --arg priority "$priority" \
        --arg toolProfile "$tool_profile" \
        --arg title "$title" \
        --arg body "$body" \
        --arg autonomyLevel "$autonomy_level" \
        --arg autonomyScope "$autonomy_scope" \
        --arg autonomyNetwork "$autonomy_network" \
        --arg autonomyCredential "$autonomy_credential" \
        --argjson createdAtUnixMs "$created_at" \
        --argjson maxTokens "$max_tokens" \
        --argjson autonomyTtl "$autonomy_ttl" \
        --argjson autonomyClean "$autonomy_clean" \
        '{
          schema:"woventeam.task_request.v0.1",
          taskId:$requestedTaskId,
          parentTaskId:$parentTaskId,
          requestedTaskId:$requestedTaskId,
          initiativeId:$initiativeId,
          requestedBy:$requestedBy,
          requestedByRole:$requestedByRole,
          requestedRole:$requestedRole,
          modelId:$modelId,
          priority:$priority,
          title:$title,
          body:$body,
          toolPolicy:{profile:$toolProfile},
          budget:{maxTokens:$maxTokens},
          createdAtUnixMs:$createdAtUnixMs
        }
        + (if $assignedAgent == "" then {} else {assignedAgent:$assignedAgent} end)
        + (if $autonomyLevel == "" then {} else {autonomyLevel:$autonomyLevel} end)
        + (if $autonomyLevel == "" and $autonomyScope == "" and $autonomyTtl == 0 then {} else {
            autonomyGrant:{
              scope:$autonomyScope,
              ttlSeconds:$autonomyTtl,
              maxWallClockSeconds:1800,
              maxTokens:$maxTokens,
              network:$autonomyNetwork,
              credentialClass:$autonomyCredential,
              requiresCleanWorktree:($autonomyClean != 0)
            }
          } end)')"
    http_post_json "/api/task-request" "$json"
}

cmd_list() {
    http_get "/api/task-summaries" | jq -r '
      .[] | [.taskId, .status, .assignedAgent, .assignedRole, .eventCount, .title] | @tsv'
}

cmd_show() {
    local task_id="${1:-}"
    if [[ -z "$task_id" ]]; then
        echo "wt-task show: TASK_ID is required" >&2
        exit 2
    fi
    http_get "/api/task-detail?taskId=$task_id" | jq .
}

cmd_initiative() {
    local subcmd="${1:-}"
    shift || true
    case "$subcmd" in
        create)
            local title="" body="" initiative="" role="project_manager" agent="router" max_tokens="2000000"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --title) title="${2:-}"; shift 2 ;;
                    --body) body="${2:-}"; shift 2 ;;
                    --id) initiative="${2:-}"; shift 2 ;;
                    --role) role="${2:-}"; shift 2 ;;
                    --agent) agent="${2:-}"; shift 2 ;;
                    --max-tokens) max_tokens="${2:-}"; shift 2 ;;
                    *) echo "wt-task initiative create: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$title" || -z "$body" ]]; then
                echo "wt-task initiative create: --title and --body are required" >&2
                exit 2
            fi
            [[ -n "$initiative" ]] || initiative="$(new_id init)"
            cmd_create --title "$title" --body "$body" --role "$role" --agent "$agent" \
                --initiative "$initiative" --tool-profile observe --max-tokens "$max_tokens"
            ;;
        list)
            http_get "/api/initiatives" | jq -r '
              .initiatives[] | [.initiativeId, .activeTasks, .taskCount, .blockedTasks, .openGateTasks, .maxTokens, .title] | @tsv'
            ;;
        show)
            local initiative="${1:-}"
            if [[ -z "$initiative" ]]; then
                echo "wt-task initiative show: INIT is required" >&2
                exit 2
            fi
            http_get "/api/initiative-detail?initiativeId=$initiative" | jq .
            ;;
        export)
            local initiative="${1:-}"
            if [[ -z "$initiative" ]]; then
                echo "wt-task initiative export: INIT is required" >&2
                exit 2
            fi
            http_get "/api/initiative-detail?initiativeId=$initiative" | jq .
            ;;
        report)
            # Phase 3 Sprint 7: render the initiative audit as a self-contained
            # HTML report (the v1.0 self-improvement demo feature). Reads the
            # same /api/initiative-audit JSON the CLI `audit` verb streams and
            # transforms it with jq (@html-escaped) into a single file with
            # inline CSS - no external assets, no new dependency.
            local initiative="${1:-}" out=""
            shift || true
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --out) out="${2:-}"; shift 2 ;;
                    *) echo "wt-task initiative report: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$initiative" ]]; then
                echo "wt-task initiative report: INIT is required" >&2
                exit 2
            fi
            local audit
            audit="$(http_get "/api/initiative-audit?initiativeId=$initiative")"
            if [[ "$(jq -r '.ok // false' <<<"$audit")" != "true" ]]; then
                echo "wt-task initiative report: initiative not found or audit failed" >&2
                exit 1
            fi
            local generated
            generated="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
            render_initiative_report "$audit" "$generated" > "${out:-/dev/stdout}"
            if [[ -n "$out" ]]; then
                echo "wrote $initiative report -> $out" >&2
            fi
            ;;
        close)
            local initiative="${1:-}" message="Initiative closed by wt-task."
            shift || true
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --message) message="${2:-}"; shift 2 ;;
                    *) echo "wt-task initiative close: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$initiative" ]]; then
                echo "wt-task initiative close: INIT is required" >&2
                exit 2
            fi
            http_get "/api/initiative-detail?initiativeId=$initiative" |
              jq -r '.tasks[] | select(.status as $s | ["complete","failed","cancelled","closed"] | index($s) | not) | .taskId' |
              while read -r task_id; do
                  [[ -n "$task_id" ]] || continue
                  cmd_lifecycle closed "$message" "$task_id" >/dev/null
              done
            http_get "/api/initiative-detail?initiativeId=$initiative" | jq .
            ;;
        -h|--help|help|"")
            usage
            ;;
        *)
            echo "wt-task initiative: unknown command: $subcmd" >&2
            usage >&2
            exit 2
            ;;
    esac
}

cmd_agent() {
    local subcmd="${1:-}"
    shift || true
    case "$subcmd" in
        list)
            http_get "/api/agents" | jq -r '
              .agents[] | [.agent, .state, .activeTasks, .leasedTasks, .runningTasks, .stuckTasks, .attempts, .message] | @tsv'
            ;;
        pause|resume)
            local agent="${1:-}" message=""
            shift || true
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --message) message="${2:-}"; shift 2 ;;
                    *) echo "wt-task agent $subcmd: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$agent" ]]; then
                echo "wt-task agent $subcmd: AGENT is required" >&2
                exit 2
            fi
            [[ -n "$message" ]] || message="Agent $subcmd requested by wt-task."
            jq -cn --arg agent "$agent" --arg action "$subcmd" --arg message "$message" \
                '{agent:$agent,action:$action,message:$message,createdBy:"ceo"}' |
              http_post_json "/api/agent-control" "$(cat)"
            ;;
        -h|--help|help|"")
            usage
            ;;
        *)
            echo "wt-task agent: unknown command: $subcmd" >&2
            usage >&2
            exit 2
            ;;
    esac
}

# Sprint 4: artifact promotion CLI. Subcommands cover the full state lifecycle
# (promote = accepted, reject, review = reviewed, supersede = superseded) plus
# operator-friendly 'note' (records a 'reviewed' state with notes only) and
# 'list' / 'export' helpers. All decisions are recorded via POST
# /api/task-artifact so the durable JSONL ledger stays the source of truth.
cmd_artifact() {
    local subcmd="${1:-}"
    shift || true
    case "$subcmd" in
        promote|reject|review|supersede)
            local task_id="${1:-}" path="" reviewer="ceo" notes=""
            shift || true
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --path) path="${2:-}"; shift 2 ;;
                    --reviewer) reviewer="${2:-}"; shift 2 ;;
                    --notes) notes="${2:-}"; shift 2 ;;
                    *) echo "wt-task artifact $subcmd: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$task_id" ]]; then
                echo "wt-task artifact $subcmd: TASK_ID is required" >&2
                exit 2
            fi
            # Map CLI verb to durable state name. 'promote' is the operator's
            # term; 'accepted' is the schema-level state recorded in the ledger.
            local state="$subcmd"
            case "$subcmd" in
                promote) state="accepted" ;;
                review) state="reviewed" ;;
                reject) state="rejected" ;;
                supersede) state="superseded" ;;
            esac
            jq -cn --arg taskId "$task_id" --arg state "$state" --arg reviewer "$reviewer" \
                --arg notes "$notes" --arg path "$path" \
                '{taskId:$taskId,state:$state,reviewer:$reviewer,notes:$notes,artifactPath:$path}' |
              http_post_json "/api/task-artifact" "$(cat)"
            ;;
        note)
            local task_id="${1:-}" reviewer="ceo" notes=""
            shift || true
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --notes) notes="${2:-}"; shift 2 ;;
                    --reviewer) reviewer="${2:-}"; shift 2 ;;
                    *) echo "wt-task artifact note: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$task_id" || -z "$notes" ]]; then
                echo "wt-task artifact note: TASK_ID and --notes are required" >&2
                exit 2
            fi
            jq -cn --arg taskId "$task_id" --arg state "reviewed" --arg reviewer "$reviewer" \
                --arg notes "$notes" --arg path "" \
                '{taskId:$taskId,state:$state,reviewer:$reviewer,notes:$notes,artifactPath:$path}' |
              http_post_json "/api/task-artifact" "$(cat)"
            ;;
        list)
            local initiative="${1:-}"
            if [[ -z "$initiative" ]]; then
                echo "wt-task artifact list: INIT is required" >&2
                exit 2
            fi
            http_get "/api/initiative-artifacts?initiativeId=$initiative" | jq -r '
              .artifacts[] |
              [.taskId, .artifactState, .acceptedArtifactPath, .lastReviewer, .lastReviewNotes, .title] | @tsv'
            ;;
        export)
            # Print the accepted artifact's contents to stdout (or to --out).
            # Sources the path from the projection; falls back to result.md when
            # no explicit accepted path is recorded yet.
            local task_id="${1:-}" out=""
            shift || true
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --out) out="${2:-}"; shift 2 ;;
                    *) echo "wt-task artifact export: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$task_id" ]]; then
                echo "wt-task artifact export: TASK_ID is required" >&2
                exit 2
            fi
            local detail accepted_path text
            detail="$(http_get "/api/task-detail?taskId=$task_id")"
            accepted_path="$(jq -r '.task.acceptedArtifactPath // ""' <<<"$detail")"
            [[ -n "$accepted_path" ]] || accepted_path="result.md"
            text="$(http_get "/api/task-artifacts?taskId=$task_id" | jq -r --arg name "$accepted_path" '
              if $name == "result.md" then .resultText
              elif $name == "stdout.log" then .stdoutText
              elif $name == "stderr.log" then .stderrText
              elif $name == "manifest.json" then .manifestText
              else .resultText end')"
            if [[ -n "$out" ]]; then
                printf '%s' "$text" >"$out"
                echo "exported $task_id ($accepted_path) -> $out"
            else
                printf '%s' "$text"
            fi
            ;;
        ship)
            # Phase 3 Sprint 3: ship an accepted artifact through one of
            # four packaging modes: copy (default), tarball, branch,
            # pull-request. branch/pr require --repo PATH; pr also requires
            # --yes.
            local task_id="${1:-}"
            shift || true
            local mode="copy" reviewer="ceo" supersedes="" repo="" yes="" prTitle="" prBody="" dest=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --mode) mode="${2:-}"; shift 2 ;;
                    --reviewer) reviewer="${2:-}"; shift 2 ;;
                    --supersedes) supersedes="${2:-}"; shift 2 ;;
                    --repo) repo="${2:-}"; shift 2 ;;
                    --yes) yes="1"; shift ;;
                    --pr-title) prTitle="${2:-}"; shift 2 ;;
                    --pr-body) prBody="${2:-}"; shift 2 ;;
                    --dest-basename) dest="${2:-}"; shift 2 ;;
                    *) echo "wt-task artifact ship: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$task_id" ]]; then
                echo "wt-task artifact ship: TASK_ID is required" >&2
                exit 2
            fi
            case "$mode" in copy|tarball|branch|pr|pull-request) ;; *) echo "wt-task artifact ship: invalid --mode" >&2; exit 2 ;; esac
            local yes_json="false"
            [[ -n "$yes" ]] && yes_json="true"
            jq -cn --arg taskId "$task_id" --arg mode "$mode" --arg reviewer "$reviewer" \
                --arg supersedes "$supersedes" --arg repoPath "$repo" \
                --arg prTitle "$prTitle" --arg prBody "$prBody" --arg destBasename "$dest" \
                --argjson yes "$yes_json" \
                '{taskId:$taskId,mode:$mode,reviewer:$reviewer,supersedes:$supersedes,
                  repoPath:$repoPath,prTitle:$prTitle,prBody:$prBody,destBasename:$destBasename,yes:$yes}' |
              http_post_json "/api/task-deliverable" "$(cat)"
            ;;
        -h|--help|help|"")
            usage
            ;;
        *)
            echo "wt-task artifact: unknown command: $subcmd" >&2
            usage >&2
            exit 2
            ;;
    esac
}

# Phase 3 Sprint 1: cancel a running task. Distinct from the existing
# `cancel` lifecycle verb (which sets task status=cancelled). cancel-task
# instructs wt-agent to terminate the running adapter process group via the
# new POST /api/task-cancel + kill_event ledger record.
cmd_cancel_task() {
    local task_id="${1:-}" reason="operator" message=""
    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reason) reason="${2:-}"; shift 2 ;;
            --message) message="${2:-}"; shift 2 ;;
            *) echo "wt-task cancel-task: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$task_id" ]]; then
        echo "wt-task cancel-task: TASK_ID is required" >&2
        exit 2
    fi
    [[ -n "$message" ]] || message="Cancel requested by wt-task ($reason)."
    jq -cn --arg taskId "$task_id" --arg reason "$reason" --arg message "$message" \
        '{taskId:$taskId,reason:$reason,message:$message,createdBy:"ceo"}' |
      http_post_json "/api/task-cancel" "$(cat)"
}

# Sprint 5: audit export. Returns the combined initiative audit report from
# /api/initiative-audit and streams to stdout (default) or --out FILE.
cmd_audit() {
    local initiative="${1:-}" out=""
    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --out) out="${2:-}"; shift 2 ;;
            *) echo "wt-task audit: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$initiative" ]]; then
        echo "wt-task audit: INIT is required" >&2
        exit 2
    fi
    if [[ -n "$out" ]]; then
        http_get "/api/initiative-audit?initiativeId=$initiative" >"$out"
        echo "audit written to $out"
    else
        http_get "/api/initiative-audit?initiativeId=$initiative" | jq .
    fi
}

# Sprint 3 closeout: operator reclaim path. Releases the most recent lease so a
# stuck task returns to the queued pool. Reason defaults to "operator" - the
# only other allowed value is "lease_expired" which the daemon also accepts when
# an automated workflow detects an expired lease.
cmd_reclaim() {
    local task_id="${1:-}" reason="operator" message=""
    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reason) reason="${2:-}"; shift 2 ;;
            --message) message="${2:-}"; shift 2 ;;
            *) echo "wt-task reclaim: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$task_id" ]]; then
        echo "wt-task reclaim: TASK_ID is required" >&2
        exit 2
    fi
    if [[ "$reason" != "operator" && "$reason" != "lease_expired" ]]; then
        echo "wt-task reclaim: --reason must be operator or lease_expired" >&2
        exit 2
    fi
    [[ -n "$message" ]] || message="Lease reclaimed by wt-task ($reason)."
    jq -cn --arg taskId "$task_id" --arg reason "$reason" --arg message "$message" \
        '{taskId:$taskId,reason:$reason,message:$message,createdBy:"ceo"}' |
      http_post_json "/api/task-reclaim" "$(cat)"
}

cmd_lifecycle() {
    local status="$1" default_message="$2" task_id="${3:-}" message=""
    shift || true
    shift || true
    shift || true
    message="$default_message"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --message) message="${2:-}"; shift 2 ;;
            *) echo "wt-task $status: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$task_id" ]]; then
        echo "wt-task $status: TASK_ID is required" >&2
        exit 2
    fi
    local created_at json
    created_at="$(now_ms)"
    json="$(jq -cn \
        --arg taskId "$task_id" \
        --arg status "$status" \
        --arg message "$message" \
        --arg createdBy "ceo" \
        --argjson createdAtUnixMs "$created_at" \
        '{schema:"woventeam.task_event.v0.1",taskId:$taskId,eventType:"lifecycle",status:$status,message:$message,createdBy:$createdBy,createdAtUnixMs:$createdAtUnixMs}')"
    http_post_json "/api/task-event" "$json"
}

cmd_assign() {
    local task_id="${1:-}" agent="" status="assigned"
    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent) agent="${2:-}"; shift 2 ;;
            --status) status="${2:-}"; shift 2 ;;
            *) echo "wt-task assign: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$task_id" || -z "$agent" ]]; then
        echo "wt-task assign: TASK_ID and --agent are required" >&2
        exit 2
    fi
    local created_at json
    created_at="$(now_ms)"
    json="$(jq -cn \
        --arg taskId "$task_id" \
        --arg status "$status" \
        --arg assignedAgent "$agent" \
        --arg createdBy "ceo" \
        --argjson createdAtUnixMs "$created_at" \
        '{schema:"woventeam.task_event.v0.1",taskId:$taskId,eventType:"assignment",status:$status,assignedAgent:$assignedAgent,message:"Task assigned by wt-task.",createdBy:$createdBy,createdAtUnixMs:$createdAtUnixMs}')"
    http_post_json "/api/task-event" "$json"
}

cmd_update_status() {
    local task_id="${1:-}" status="" message="Task status updated by wt-task."
    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status) status="${2:-}"; shift 2 ;;
            --message) message="${2:-}"; shift 2 ;;
            *) echo "wt-task update-status: unknown argument: $1" >&2; usage >&2; exit 2 ;;
        esac
    done
    if [[ -z "$task_id" || -z "$status" ]]; then
        echo "wt-task update-status: TASK_ID and --status are required" >&2
        exit 2
    fi
    local created_at json
    created_at="$(now_ms)"
    json="$(jq -cn \
        --arg taskId "$task_id" \
        --arg status "$status" \
        --arg message "$message" \
        --arg createdBy "ceo" \
        --argjson createdAtUnixMs "$created_at" \
        '{schema:"woventeam.task_event.v0.1",taskId:$taskId,eventType:"status",status:$status,message:$message,createdBy:$createdBy,createdAtUnixMs:$createdAtUnixMs}')"
    http_post_json "/api/task-event" "$json"
}

cmd_autonomy() {
    local sub="${1:-}"
    shift || true
    case "$sub" in
        revoke)
            local task_id="${1:-}" reason="operator autonomy revocation"
            shift || true
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --reason) reason="${2:-}"; shift 2 ;;
                    *) echo "wt-task autonomy revoke: unknown argument: $1" >&2; usage >&2; exit 2 ;;
                esac
            done
            if [[ -z "$task_id" ]]; then
                echo "wt-task autonomy revoke: TASK_ID is required" >&2
                exit 2
            fi
            local json
            json="$(jq -cn --arg taskId "$task_id" --arg reason "$reason" \
                '{taskId:$taskId,reason:$reason,createdBy:"ceo"}')"
            http_post_json "/api/autonomy-revoke" "$json"
            ;;
        *) echo "wt-task autonomy: expected revoke" >&2; usage >&2; exit 2 ;;
    esac
}

require_jq
cmd="${1:-}"
shift || true
case "$cmd" in
    create) cmd_create "$@" ;;
    request) cmd_request "$@" ;;
    initiative) cmd_initiative "$@" ;;
    agent) cmd_agent "$@" ;;
    list) cmd_list "$@" ;;
    show) cmd_show "$@" ;;
    assign) cmd_assign "$@" ;;
    update-status) cmd_update_status "$@" ;;
    reclaim) cmd_reclaim "$@" ;;
    cancel-task) cmd_cancel_task "$@" ;;
    artifact) cmd_artifact "$@" ;;
    audit) cmd_audit "$@" ;;
    autonomy) cmd_autonomy "$@" ;;
    retry) cmd_lifecycle queued "Task reopened for retry by wt-task." "$@" ;;
    cancel) cmd_lifecycle cancelled "Task cancelled by wt-task." "$@" ;;
    close) cmd_lifecycle closed "Task closed by wt-task." "$@" ;;
    reopen) cmd_lifecycle queued "Task reopened by wt-task." "$@" ;;
    -h|--help|help|"") usage ;;
    *) echo "wt-task: unknown command: $cmd" >&2; usage >&2; exit 2 ;;
esac
