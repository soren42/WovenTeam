{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solariangroup.com/woventeam/schemas/task-package-v0.1.json",
  "title": "WovenTeam Task Package v0.1",
  "description": "A structured assignment package that binds a role, task, agent, model, context, and execution policy for Phase 0 orchestration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "taskId",
    "initiativeId",
    "createdBy",
    "assignedRole",
    "task",
    "acceptanceCriteria",
    "toolPolicy"
  ],
  "properties": {
    "schema": {
      "const": "woventeam.task_package.v0.1"
    },
    "taskId": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9][A-Za-z0-9_.-]{2,96}$"
    },
    "initiativeId": {
      "type": "string",
      "pattern": "^init_[A-Za-z0-9][A-Za-z0-9_.-]{2,96}$"
    },
    "parentTaskId": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9][A-Za-z0-9_.-]{2,96}$"
    },
    "requestedByRole": {
      "type": "string",
      "enum": ["program_manager", "project_manager"],
      "description": "Manager role that requested this child package through task.request."
    },
    "createdBy": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64
    },
    "assignedRole": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,63}$"
    },
    "assignedAgent": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "modelId": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+/[A-Za-z0-9_.-]+$"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "urgent"],
      "default": "normal"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "queued", "assigned", "running", "blocked", "complete", "failed", "cancelled", "closed"],
      "default": "queued"
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 160
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "deliverables": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160,
      "description": "Phase 0 native projection of task.title for the C ledger scanner."
    },
    "body": {
      "type": "string",
      "minLength": 1,
      "description": "Phase 0 native projection of task.body for the C ledger scanner."
    },
    "contextRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "ref"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["file", "directory", "url", "message", "artifact", "note"]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "toolPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile"],
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["observe", "repo_branch", "test_local", "ops_read", "ops_change"]
        },
        "filesystem": {
          "type": "string",
          "enum": ["none", "read_only", "workspace_write", "explicit_paths"]
        },
        "network": {
          "type": "string",
          "enum": ["none", "loopback", "intranet", "internet"]
        },
        "system": {
          "type": "string",
          "enum": ["none", "status_only", "approved_commands"]
        },
        "git": {
          "type": "string",
          "enum": ["none", "branch_only", "commit_allowed"]
        },
        "allowedPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "deniedPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400,
          "default": 1800
        },
        "maxOutputBytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 10485760,
          "default": 1048576
        },
        "maxCostUsd": {
          "type": "number",
          "minimum": 0,
          "default": 1.0
        },
        "maxTokens": {
          "type": "integer",
          "minimum": 0,
          "default": 2000000,
          "description": "Phase 0 allocation budget used by token telemetry. Adapter-reported usage is a later subsystem."
        }
      },
      "default": {}
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^task_[A-Za-z0-9][A-Za-z0-9_.-]{2,96}$"
      },
      "default": []
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "default": {}
    },
    "createdAtUnixMs": {
      "type": "integer",
      "minimum": 0,
      "description": "Phase 0 native timestamp projection used by the append-only task ledger."
    }
  }
}
